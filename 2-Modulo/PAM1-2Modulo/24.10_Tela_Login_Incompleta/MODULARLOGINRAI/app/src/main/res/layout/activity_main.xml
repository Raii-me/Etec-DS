<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111212"
    tools:context=".MainActivity">

    <TextView android:id="@+id/txt_titulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Login"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_marginTop="40dp"
    />

    <EditText android:id="@+id/edt_nome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Digite seu nome"
        android:layout_margin="20dp"
        android:padding="10dp"
        android:textColor="@color/black"
        android:background="@drawable/redondo"
        />

    <EditText android:id="@+id/edt_email"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Digite seu email"
        android:layout_margin="20dp"
        android:padding="10dp"
        android:textColor="@color/black"
        android:background="@drawable/redondo"
        />

    <EditText android:id="@+id/edt_senha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Digite sua senha"
        android:layout_margin="20dp"
        android:padding="10dp"
        android:textColor="@color/black"
        android:background="@drawable/redondo"
        android:inputType="textPassword"
        />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp">
        <Button android:id="@+id/btn_entrar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#D32F2F"
            android:text="Entrar"
            android:textSize="18dp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:cornerRadius="5dp"/>

        <Button android:id="@+id/btn_criar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#626262"
            android:text="Sair"
            android:layout_marginStart="20dp"
            android:textSize="18dp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:cornerRadius="5dp"/>

        </LinearLayout>

    <CheckBox android:id="@+id/credencial"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/white"
        android:text="Lembrar das minhas informações"
        android:textColor="@color/white"
        android:layout_marginStart="20dp"/>

</LinearLayout>