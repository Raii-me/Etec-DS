<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ADC8B3"
    android:orientation="vertical"
    tools:context=".ImcActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/imc_desk"
        android:padding="20dp"
        android:textColor="@color/black"
        android:layout_marginBottom="40dp"
        android:textSize="15dp"
        android:textStyle="bold"
        />

    <EditText android:id="@+id/edt_peso"
        style="@style/from"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/PESO"
        android:padding="20dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="10dp"
        android:background="#A0D098"
        />

    <EditText android:id="@+id/edt_altura"
        style="@style/from"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/ALTURA"
        android:padding="20dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="10dp"
        android:background="#A0D098"
        />

    <Button android:id="@+id/btn_Calcular"
        android:layout_width="match_parent"
        style="@style/from"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_margin="30dp"
        android:padding="15dp"
        android:backgroundTint="#A9E9A6"
        android:text="@string/calc"
        android:textColor="@color/black"
        app:cornerRadius="10dp"
        />


</LinearLayout>