<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="@android:color/transparent"/> <!-- fundo transparente ou coloque uma cor -->

    <stroke
        android:width="2dp"
        android:color="#000000" /> <!-- cor da borda -->

    <corners android:radius="8dp"/> <!-- opcional: arredondar borda -->

    <padding
        android:left="8dp"
        android:right="8dp"
        android:top="4dp"
        android:bottom="4dp"/>
</shape>
